# ─── App ───────────────────────────────────────────────────────────────────
# Public base URL of this app (used for redirect URIs and the bookmarklet).
APP_BASE_URL=https://soundpull.example.org
# Signs the NiceGUI/Starlette session cookie.  SECRET — generate with:  openssl rand -hex 32
SESSION_SECRET=change-me-openssl-rand-hex-32
# Key for encrypting WebDAV passwords at rest.  SECRET — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# ─── OIDC / authentik ────────────────────────────────────────────────────────
# OpenID discovery document of your authentik application.
OIDC_DISCOVERY_URL=https://auth.example.org/application/o/soundpull/.well-known/openid-configuration
OIDC_CLIENT_ID=change-me
# SECRET
OIDC_CLIENT_SECRET=change-me
# Must EXACTLY match the redirect URI configured on the authentik provider.
OIDC_REDIRECT_URI=https://soundpull.example.org/auth/callback
OIDC_SCOPES=openid email profile
# Optional: restrict access to members of this authentik group (from the `groups` claim).
# Leave empty to allow any authentik user that can open the application.
OIDC_ALLOWED_GROUP=

# Optional: where authentik should send the user after logout (RP-initiated logout).
OIDC_POST_LOGOUT_REDIRECT=

# ─── Storage ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////data/app.db
# Staging/temp dir for downloads (ZIP packaging + WebDAV work dir).
LOCAL_MUSIC_ROOT=/downloads
# Max downloads running at the same time across all users.
MAX_CONCURRENT_DOWNLOADS=2
# Cap on the number of tracks fetched from a single playlist. 0 = unlimited.
MAX_PLAYLIST_ITEMS=100
# Albums downloaded in parallel within one artist download (1–4).
MAX_ARTIST_ALBUM_CONCURRENCY=3

# ─── Throttle resilience for multi-track runs (album / playlist / artist) ────
# A marathon of big downloads can get the IP temporarily rate-limited; yt-dlp then
# silently skips the throttled tracks, so an album comes out partial. These make it
# recoverable and visible (parity-safe — only affect timing / which tracks retry):
#   DOWNLOAD_RETRY_PASSES        — extra re-runs that re-attempt only the still-missing
#                                  tracks (per-job download archive). 0 = no retry.
#   DOWNLOAD_RETRY_BACKOFF_SECONDS — wait before each retry pass so a throttle can clear.
#   DOWNLOAD_SLEEP_REQUESTS_SECONDS — paced delay between HTTP requests to AVOID throttling
#                                  (0 = off/fastest; try 0.5 when pulling whole discographies).
#   DOWNLOAD_SOCKET_TIMEOUT_SECONDS — cap per-socket wait so a STALLED connection can't hang a
#                                  worker thread forever (0 = yt-dlp default / no timeout).
DOWNLOAD_RETRY_PASSES=2
DOWNLOAD_RETRY_BACKOFF_SECONDS=30
DOWNLOAD_SLEEP_REQUESTS_SECONDS=0
DOWNLOAD_SOCKET_TIMEOUT_SECONDS=60

# ─── PO-token provider (YouTube GVS 403 fix) ─────────────────────────────────
# YouTube now requires a GVS PO token for most audio formats; without one the
# affected clients return HTTP 403. The bundled yt-dlp plugin fetches tokens from
# a bgutil-ytdlp-pot-provider server. The docker-compose sidecar sets this for you;
# override only if you run the provider elsewhere. Empty = disabled (falls back to
# token-free clients at reduced audio quality).
POT_PROVIDER_BASE_URL=http://bgutil-provider:4416

# ─── Playlist interval-sync (issue #21) ──────────────────────────────────────
# Master switch for the background scheduler that auto-syncs subscribed playlists.
SYNC_ENABLED=true
# How often (seconds) the scheduler checks for due subscriptions. The per-playlist
# cadence itself is set per subscription (interval_hours) in the UI.
SYNC_TICK_SECONDS=60

# Optional SSRF guard: comma-separated allowlist of permitted WebDAV hosts
# (e.g. cloud.intern.org,dav.example.org). Empty = no restriction.
WEBDAV_ALLOWED_HOSTS=
